# =============================================================================
# NexusRAG — Environment Configuration
# Copy file này thành .env và chỉnh sửa theo môi trường của bạn
# =============================================================================


# =============================================================================
# INFRASTRUCTURE — Services
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/nexusrag

# ChromaDB (vector store)
CHROMA_HOST=localhost
CHROMA_PORT=8002

# RabbitMQ (task queue)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# MinIO (object storage — raw uploads + parsed markdown)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=nexusrag-uploads
MINIO_BUCKET_MARKDOWN=nexusrag-markdown
MINIO_SECURE=false
# false = publish ParseMessage ngay sau upload (dev, không cần webhook)
# true  = chờ MinIO S3 event webhook tại /api/v1/minio/events (production)
MINIO_WEBHOOK_ENABLED=false
# URL MinIO mà browser có thể reach trực tiếp (dùng cho presigned PUT URL)
# Docker local dev: http://localhost:9000
# Production server: http://your-server-ip:9000 hoặc https://minio.yourdomain.com
MINIO_PUBLIC_ENDPOINT=http://localhost:9000


# =============================================================================
# LLM — Chat & KG extraction
# Chọn 1 trong 2 provider: gemini | ollama
# =============================================================================

LLM_PROVIDER=openai_compatible

# --- Gemini ---
# LLM_PROVIDER=gemini
# GOOGLE_AI_API_KEY=your-api-key-here
# LLM_MODEL_FAST=gemini-2.5-flash
# LLM_MODEL_FAST=gemini-3.1-flash-lite-preview

# --- Ollama (native Ollama protocol tại port 11434) ---
# LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:8000/v1
OLLAMA_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8
# OLLAMA_MODEL=qwen3:14b        ← tốt cho KG entity extraction
# OLLAMA_MODEL=gemma3:12b       ← multimodal, tốt cho caption ảnh
# OLLAMA_MODEL=qwen3.5:9b

# --- OpenAI-compatible endpoint (vLLM, LM Studio, llama.cpp, v.v.) ---
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_COMPATIBLE_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8
OPENAI_COMPATIBLE_API_KEY=sk-gw-c9ce6a07f32047dda875eea2ac46cec7

# Thinking mode (chỉ cho model hỗ trợ, vd qwen3.5 — giảm latency nếu tắt)
OLLAMA_ENABLE_THINKING=false

# Giới hạn output tokens (bao gồm thinking tokens nếu có)
LLM_MAX_OUTPUT_TOKENS=8192

# Thinking level cho Gemini 3.x+: minimal | low | medium | high
# (Gemini 2.5 tự động dùng thinking_budget_tokens, setting này bị bỏ qua)
LLM_THINKING_LEVEL=medium


# =============================================================================
# KG EMBEDDING — Vector embedding cho Knowledge Graph (LightRAG)
# Có thể dùng provider khác với LLM provider ở trên
# =============================================================================

# local  → sentence-transformers trực tiếp trên máy (khuyến nghị khi không có Gemini key)
# gemini → Gemini Embedding API (cần GOOGLE_AI_API_KEY)
# ollama → Ollama embedding API (remote host ở trên phải có embedding endpoint)
KG_EMBEDDING_PROVIDER=local
KG_EMBEDDING_MODEL=BAAI/bge-m3
KG_EMBEDDING_DIMENSION=1024

# --- Gemini embedding (inactive) ---
# KG_EMBEDDING_PROVIDER=gemini
# KG_EMBEDDING_MODEL=gemini-embedding-001
# KG_EMBEDDING_DIMENSION=3072


# =============================================================================
# PIPELINE — Document ingestion
# =============================================================================

# Bật/tắt các tính năng
NEXUSRAG_ENABLED=true
NEXUSRAG_ENABLE_KG=true
NEXUSRAG_ENABLE_IMAGE_EXTRACTION=true
NEXUSRAG_ENABLE_IMAGE_CAPTIONING=true
NEXUSRAG_ENABLE_TABLE_CAPTIONING=true
# Tắt CodeFormulaV2 VLM (~1.5 GB VRAM) khi không cần nhận dạng công thức toán
NEXUSRAG_ENABLE_FORMULA_ENRICHMENT=true

# Chunking
NEXUSRAG_CHUNK_MAX_TOKENS=512

# Knowledge Graph
NEXUSRAG_KG_LANGUAGE=Vietnamese
NEXUSRAG_KG_ENTITY_TYPES=["Organization","Person","Product","Location","Event","Financial_Metric","Technology","Date","Regulation"]
NEXUSRAG_KG_CHUNK_TOKEN_SIZE=1200
NEXUSRAG_KG_QUERY_TIMEOUT=30.0
# Graph storage backend: networkx (file-based) | neo4j
NEXUSRAG_KG_GRAPH_BACKEND=neo4j

# Ảnh & bảng
NEXUSRAG_DOCLING_IMAGES_SCALE=2.0
NEXUSRAG_MAX_IMAGES_PER_DOC=50
NEXUSRAG_MAX_TABLE_MARKDOWN_CHARS=8000


# =============================================================================
# RETRIEVAL — Vector search & reranking
# =============================================================================

NEXUSRAG_EMBEDDING_MODEL=BAAI/bge-m3
NEXUSRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Số chunks fetch từ ChromaDB trước khi rerank
NEXUSRAG_VECTOR_PREFETCH=20
# Số chunks giữ lại sau reranking
NEXUSRAG_RERANKER_TOP_K=8
# Ngưỡng relevance score tối thiểu (0.0–1.0); chunk dưới ngưỡng bị loại
NEXUSRAG_MIN_RELEVANCE_SCORE=0.15
# Chế độ query KG: hybrid | local | global | naive
NEXUSRAG_DEFAULT_QUERY_MODE=hybrid


# =============================================================================
# GPU DEVICE PLACEMENT
# Kiểm soát worker nào dùng GPU, worker nào dùng CPU
#
# "auto" → dùng GPU nếu có (production, multi-GPU)
# "cpu"  → ép CPU (máy demo 1 GPU nhỏ để tránh OOM)
# "cuda" → ép GPU cụ thể
#
# CUDA_VISIBLE_DEVICES=1 → toàn bộ hệ thống (FastAPI + workers) chỉ dùng GPU 1
# Multi-GPU production: để "auto" + set CUDA_VISIBLE_DEVICES=N per container
#   parse_worker:  CUDA_VISIBLE_DEVICES=0
#   embed_worker:  CUDA_VISIBLE_DEVICES=1
#   kg_worker:     CUDA_VISIBLE_DEVICES=1  (hoặc GPU 2 nếu có)
# =============================================================================

# Ép toàn bộ process Python (FastAPI + workers) chỉ thấy GPU 1
CUDA_VISIBLE_DEVICES=1

# parse worker: Docling (LayoutModel ~1GB + TableFormer ~600MB)
NEXUSRAG_DOCLING_DEVICE=cuda

# embed worker + KG embedding: bge-m3 (~3.3GB GPU | ~4GB RAM khi cpu)
NEXUSRAG_EMBEDDING_DEVICE=cuda


# =============================================================================
# OCR — Xử lý PDF scan (image-based PDF)
# =============================================================================

NEXUSRAG_ENABLE_OCR=true
# Tỉ lệ trang không có selectable text để phân loại là scanned PDF (0.0–1.0)
NEXUSRAG_OCR_SCANNED_THRESHOLD=0.5

# Backend OCR:
#   false (default) → remote vLLM API tại HUNYUAN_OCR_API_URL (không cần GPU local)
#   true            → local vllm.LLM trên máy (cần pip install vllm + ~4GB VRAM)
NEXUSRAG_OCR_LOCAL=true

# --- Remote API backend (NEXUSRAG_OCR_LOCAL=false) ---
HUNYUAN_OCR_API_URL=http://10.8.0.8:8001/v1
HUNYUAN_OCR_MODEL=tencent/HunyuanOCR

# --- Local vLLM backend (NEXUSRAG_OCR_LOCAL=true) ---
# GPU để chạy OCR model.
# "auto" hoặc "" = không override CUDA_VISIBLE_DEVICES (inherit từ parent process)
# → Để "auto" khi đã set CUDA_VISIBLE_DEVICES=1 ở trên, tránh conflict.
# Chỉ đặt số cụ thể (0/1/2) khi KHÔNG set CUDA_VISIBLE_DEVICES ở cấp process.
NEXUSRAG_OCR_CUDA_DEVICE=auto
# Phần trăm VRAM dành cho KV cache của OCR model (HunyuanOCR 1B chỉ cần ~7GB)
# Mặc định vLLM=0.9 (~43GB) sẽ conflict với LLM server đang chạy → dùng 0.15-0.5
NEXUSRAG_OCR_GPU_MEMORY_UTILIZATION=0.42
# Max sequence length — phải đặt tường minh để tránh vLLM auto-probe (thường gây
# "Engine core initialization failed" trên một số GPU/driver combo).
NEXUSRAG_OCR_MAX_MODEL_LEN=4096


# =============================================================================
# CORS — Frontend origins được phép truy cập API
# =============================================================================

CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]

# =============================================================================
# NEO4J — Knowledge Graph backend (dùng khi NEXUSRAG_KG_GRAPH_BACKEND=neo4j)
# LightRAG đọc trực tiếp từ os.environ (không qua pydantic-settings)
# =============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=nexusrag123
